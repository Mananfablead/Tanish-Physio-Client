<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS + non-www (301)
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.tanishphysiofitness\.in$ [NC]
  RewriteRule ^ https://tanishphysiofitness.in%{REQUEST_URI} [R=301,L,NE]

  # SPA fallback (serve index.html for non-file/non-dir)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

